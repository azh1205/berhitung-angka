{
  "name": "math-bubbles",
  "version": "1.0.0",
  "description": "A fun math counting game with floating bubbles.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "author": "Antigravity",
  "license": "ISC",
  "build": {
    "appId": "com.mathgame.bubbles",
    "productName": "Math Bubbles",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
